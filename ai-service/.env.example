# PitchProbe environment variables
# Copy this to .env and fill in your actual keys

# Groq (LLM provider — get free key at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini (embeddings — get free key at aistudio.google.com)
GOOGLE_API_KEY=your_google_api_key_here

# Tavily (web search — get free key at tavily.com)
TAVILY_API_KEY=your_tavily_api_key_here